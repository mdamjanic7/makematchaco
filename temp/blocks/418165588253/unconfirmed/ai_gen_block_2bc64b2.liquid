      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_1_category",
      "label": "Category",
      "default": "Culture"
    },
    {
      "type": "text",
